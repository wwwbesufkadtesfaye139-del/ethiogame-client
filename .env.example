# Copy to .env.local for local dev. In Vercel, set these under
# Project Settings → Environment Variables instead.

# Sentry DSN for this client project. Safe to expose in the client bundle
# (DSNs are not secrets) — leave blank to disable crash reporting entirely.
VITE_SENTRY_DSN=

# Optional: tie Sentry events to the exact commit that shipped them.
# Vercel: set this to $VERCEL_GIT_COMMIT_SHA in the dashboard.
VITE_COMMIT_SHA=
